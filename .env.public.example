# Example public test deployment settings.
#
# Copy this file to .env or export these variables before `docker compose up`.
# Use separate hostnames or public ports that route to the three container
# services. Sub-path hosting is not supported by this local bundle.

GC_FORMS_PUBLIC_APP_URL=https://forms-test.example.com
GC_FORMS_PUBLIC_API_URL=https://forms-api-test.example.com
GC_FORMS_PUBLIC_IDP_URL=https://forms-idp-test.example.com

# App/API/IDP bind publicly by default. Keep backing services private unless you
# intentionally need to debug them from the host.
GC_FORMS_PUBLIC_BIND_IP=0.0.0.0
GC_FORMS_PRIVATE_BIND_IP=127.0.0.1

GC_FORMS_APP_PORT=3000
GC_FORMS_API_PORT=3001
GC_FORMS_IDP_PORT=8080
GC_FORMS_LOCALSTACK_PORT=4566
GC_FORMS_POSTGRES_PORT=4510
GC_FORMS_REDIS_PORT=6379
